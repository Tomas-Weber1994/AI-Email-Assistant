# ── Server Configuration ──────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=9000
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=30
MAX_ANALYZE_PASSES=6
# ── Proxy Configuration (leave empty if not behind a proxy) ──
PROXY_HOST=
PROXY_PORT=
