MANAGER_EMAIL=manager@example.com
SALES_REPLY_REQUIRES_APPROVAL=false
# ── OpenAI Configuration ─────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
MODEL_NAME=gpt-4o
